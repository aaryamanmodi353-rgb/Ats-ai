# ResumeIQ MERN Backend Environment Configuration Example

# Paste your MongoDB Connection URI here (MongoDB Atlas Cloud or Local MongoDB):
# MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxx.mongodb.net/resumeiq?retryWrites=true&w=majority
# MONGODB_URI=mongodb://127.0.0.1:27017/resumeiq

# Express Server Port (default 5000)
PORT=5000

# Optional: Anthropic API Key
# ANTHROPIC_API_KEY=sk-ant-api03-...
